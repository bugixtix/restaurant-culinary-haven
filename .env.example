# Restaurant Website Environment Variables

# API Configuration (Optional - for backend integration)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Email Service (For reservations - Optional)
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Restaurant Info
# NEXT_PUBLIC_RESTAURANT_NAME=Culinary Haven
# NEXT_PUBLIC_RESTAURANT_EMAIL=reservations@culinaryhaven.com
# NEXT_PUBLIC_RESTAURANT_PHONE=+1 (555) 123-4567
# NEXT_PUBLIC_RESTAURANT_ADDRESS=123 Gourmet Avenue, Culinary City, CC 12345
